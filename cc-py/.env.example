# Personal Command Center — Python scanner env vars
# Copy to cc-py/.env and fill in real values. NEVER commit cc-py/.env

# Supabase (NEW project, separate from any other Supabase you have)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
SUPABASE_OWNER_USER_ID=00000000-0000-0000-0000-000000000000

# Gmail OAuth — reuse existing token from the expense tracker root
# Path is RELATIVE to the repo root (the parent of cc-py/)
GMAIL_TOKEN_PATH=../gmail_token.json
GMAIL_CREDENTIALS_PATH=../credentials.json

# Scanner config
DINAROZ_SENDER=accounting@finbot.co.il
SCAN_LOOKBACK_DAYS=90
